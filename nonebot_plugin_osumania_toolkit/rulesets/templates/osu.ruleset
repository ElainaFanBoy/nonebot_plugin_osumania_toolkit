                "OsuMania": {
                    "Window320": 19.5,
                    "Window300": "{{w300 * 1.1}}",
                    "Window200": "{{w200}}",
                    "Window100": "{{w100}}",
                    "Window50": "{{w50}}",
                    "Window0": "{{w0}}",
                    "WindowOverhold200": "{{overhold200}}",
