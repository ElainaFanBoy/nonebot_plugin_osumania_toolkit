{
    "Template": {
        "Type": "formula",
        "Name": "osu",
        "Summary": "osu!mania ScoreV1",
        "ArgumentName": "diff",
        "Aliases": ["od"],
        "Default": 8.0,
        "Min": -15.0,
        "Max": 15.0,
        "Precision": 1,
        "Variables": {
            "w300": "max(1.0, 64.5 - 3 * diff)",
            "w200": "max(1.0, 97.5 - 3 * diff)",
            "w100": "max(1.0, 127.5 - 3 * diff)",
            "w50": "max(1.0, 151.5 - 3 * diff)",
            "w0": "max(1.0, 188.5 - 3 * diff)",
            "w100_late": "max(1.0, w100 - 1.0)",
            "w50_late": "max(1.0, w50 - 25.0)",
            "w0_late": "max(1.0, w0 - 62.0)",
            "overhold200": 16.5,
            "overhold100": "max(1.0, 79.5 + (8.0 - diff) * 3.0)"
        }
    },
    "Ruleset": {
        "Name": "osu! OD{{diff}}",
        "Description": "Simulates osu!mania scoring with OD={{diff}}",
        "Judgements": [
            {
                "Name": "300g",
                "Color": [255, 0, 255, 255],
                "BreaksCombo": false,
                "TimingWindows": [-16.5, 16.5]
            },
            {
                "Name": "300",
                "Color": [255, 255, 255, 0],
                "BreaksCombo": false,
                "TimingWindows": ["{{-w300}}", "{{w300}}"]
            },
            {
                "Name": "200",
                "Color": [255, 0, 255, 100],
                "BreaksCombo": false,
                "TimingWindows": ["{{-w200}}", "{{w200}}"]
            },
            {
                "Name": "100",
                "Color": [255, 0, 160, 255],
                "BreaksCombo": false,
                "TimingWindows": ["{{-w100}}", "{{w100_late}}"]
            },
            {
                "Name": "50",
                "Color": [255, 160, 160, 160],
                "BreaksCombo": false,
                "TimingWindows": ["{{-w50}}", "{{w50_late}}"]
            },
            {
                "Name": "MISS",
                "Color": [255, 255, 80, 80],
                "BreaksCombo": true,
                "TimingWindows": ["{{-w0}}", "{{w0_late}}"]
            }
        ],
        "Lamps": [
            {
                "Name": "SDCB",
                "Color": [255, 255, 160, 160],
                "Requirement": { "ComboBreaksAtMost": 9 }
            },
